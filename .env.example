# Telegram
TELEGRAM_BOT_TOKEN=123456:your-bot-token-from-botfather
# ID чата куда будут падать уведомления о новых заказах (личный чат менеджера)
MANAGER_CHAT_ID=123456789
# Telegram user ID администратора — кому доступны /reindex, /stats
ADMIN_USER_ID=123456789

# LLM (Groq — бесплатный tier, console.groq.com)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# PostgreSQL с расширением pgvector
# Локально:  postgres://postgres:postgres@localhost:5432/shopbot
# Railway:   автоматически подставит DATABASE_URL при добавлении PostgreSQL сервиса
DATABASE_URL=postgres://postgres:postgres@localhost:5432/shopbot

# Redis для памяти диалога и rate-limiting
# Локально:  redis://localhost:6379
# Railway:   автоматически подставит REDIS_URL при добавлении Redis сервиса
REDIS_URL=redis://localhost:6379

# Опционально: ограничение скорости (по умолчанию 20 сообщений/мин на пользователя)
RATE_LIMIT_PER_MINUTE=20

# === Bot mode ===
# polling (по умолчанию) — бот сам долбит getUpdates(). Просто работает.
# webhook                — Telegram пушит апдейты в наш HTTP-сервер на $WEBHOOK_PATH.
#                          Эффективнее под нагрузкой; требует публично доступного HTTPS-домена.
BOT_MODE=polling

# Если BOT_MODE=webhook — обязательно:
# WEBHOOK_DOMAIN=https://your-host.example.com
# WEBHOOK_PATH=/telegram/webhook
# Опционально (рекомендуется): секрет в заголовке X-Telegram-Bot-Api-Secret-Token
# WEBHOOK_SECRET_TOKEN=случайная-строка-не-менее-32-символов

# === Embedding cache ===
# TTL для кэша эмбеддингов в Redis (секунды). По умолчанию 7 дней.
# EMBEDDING_CACHE_TTL_SECONDS=604800

# === Telegram Payments ===
# Токен платёжного провайдера от @BotFather (/mybots → Payments).
# Без токена checkout остаётся ручным — менеджер списывается с клиентом.
# PAYMENT_PROVIDER_TOKEN=
# Валюта инвойса (ISO 4217). Telegram поддерживает RUB, USD, EUR и др.
# PAYMENT_CURRENCY=RUB

# === Voice messages (Whisper via Groq) ===
# Модель для транскрипции голосовых. По умолчанию whisper-large-v3-turbo
# (быстрее large-v3 при сравнимом качестве).
# WHISPER_MODEL=whisper-large-v3-turbo
# Максимальная длительность голосового, секунды. По умолчанию 60.
# MAX_VOICE_SECONDS=60
# Максимальный размер файла, байт. По умолчанию 20 MB (лимит Telegram Bot API).
# MAX_VOICE_BYTES=20971520

# === Телеметрия (опционально) ===
# Sentry: error tracking + perf-tracing. Без DSN — модуль no-op, оверхеда нет.
# SENTRY_DSN=https://abc123@o000.ingest.sentry.io/000
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=ai-consultant-for-the-store@1.5.0
# SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry: распределённый трейсинг через OTLP/HTTP. Без endpoint — no-op.
# Активируется только если SENTRY_DSN НЕ задан (Sentry сам поднимает OTel внутри).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=ai-consultant-for-the-store

# === A/B-тестирование system-prompt'а ===
# Через запятую: какие варианты держим активными. Без env — только baseline.
# Допустимые id: baseline, sales_focused, concise (см. src/prompt-ab.ts).
# Распределение по пользователям детерминированное (sha256 от userId).
# PROMPT_AB_VARIANTS=baseline,sales_focused,concise
